{
  "rewrites": [
    { "handle": "filesystem" },
    {
      "src": "^/api/(.*)",
      "dest": "https://baatkaro-backend.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://baatkaro-backend.onrender.com/socket.io/$1"
    }
  ]
}